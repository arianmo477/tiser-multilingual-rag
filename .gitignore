# --- Regenerable RAG artifacts (rebuilt by multilingual_rag_tiser/rag/build_rag_index.py) ---
# Derived from the training splits; never edit by hand. See docs/DATA.md.
data/rag/*/index.faiss
data/rag/*/documents.json

# --- Experiment outputs ---
# Keep result JSONs (gen_*.json, summary.json) in the repo: they back the
# numbers in the paper. Ignore only model weights and trainer checkpoints.
experiments/**/checkpoint-*/
experiments/**/*.safetensors
experiments/**/*.bin
experiments/**/*.pt
experiments/**/runs/          # tensorboard logs, if any

# --- Python ---
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# --- LaTeX build artifacts ---
docs/*.aux
docs/*.log
docs/*.out
docs/*.bbl
docs/*.blg
docs/*.synctex.gz

# --- OS / editor ---
.DS_Store